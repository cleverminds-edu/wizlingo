generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model School {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  logoUrl   String?
  createdAt DateTime  @default(now())
  admins    Admin[]
  classes   Class[]
  teachers  Teacher[]
}

model Admin {
  id        String    @id @default(cuid())
  name      String
  empCode   String    @unique
  pin       String
  role      AdminRole
  schoolId  String
  createdAt DateTime  @default(now())
  school    School    @relation(fields: [schoolId], references: [id])
}

model Teacher {
  id        String   @id @default(cuid())
  name      String
  empCode   String   @unique
  pin       String
  schoolId  String
  createdAt DateTime @default(now())
  classes   Class[]
  school    School   @relation(fields: [schoolId], references: [id])
}

model Class {
  id        String    @id @default(cuid())
  grade     Int
  section   String
  schoolId  String
  teacherId String?
  school    School    @relation(fields: [schoolId], references: [id])
  teacher   Teacher?  @relation(fields: [teacherId], references: [id])
  students  Student[]
}

model Student {
  id               String            @id @default(cuid())
  name             String
  admissionNumber  String            @unique
  pin              String
  classId          String
  accountType      AccountType       @default(SCHOOL)
  gender           Gender?
  createdAt        DateTime          @default(now())
  badges           Badge[]
  certificates     Certificate[]
  sessions         ReadingSession[]
  speakingProgress SpeakingProgress?
  speakingSessions SpeakingSession[]
  class            Class             @relation(fields: [classId], references: [id])
  progress         StudentProgress?
}

model StudentProgress {
  id             String    @id @default(cuid())
  studentId      String    @unique
  currentLevel   Int       @default(1)
  gradeBand      GradeBand
  totalSessions  Int       @default(0)
  passedSessions Int       @default(0)
  avgWpm         Float     @default(0)
  avgAccuracy    Float     @default(0)
  avgFluency     Float     @default(0)
  updatedAt      DateTime  @updatedAt
  student        Student   @relation(fields: [studentId], references: [id])
}

model ReadingPassage {
  id        String           @id @default(cuid())
  title     String
  content   String
  wordCount Int
  gradeBand GradeBand
  level     Int
  topic     String
  createdAt DateTime         @default(now())
  sessions  ReadingSession[]
}

model ConversationTopic {
  id          String            @id @default(cuid())
  title       String
  gradeBand   GradeBand
  level       Int
  character   String
  openingLine String
  mode        TopicMode         @default(SCRIPTED)
  script      Json?
  createdAt   DateTime          @default(now())
  sessions    SpeakingSession[]
}

model SpeakingSession {
  id           String            @id @default(cuid())
  studentId    String
  topicId      String
  startedAt    DateTime          @default(now())
  completedAt  DateTime?
  turns        Json?
  totalWords   Int?
  durationSec  Int?
  wpm          Float?
  fluencyScore Float?
  status       SessionStatus     @default(IN_PROGRESS)
  createdAt    DateTime          @default(now())
  student      Student           @relation(fields: [studentId], references: [id])
  topic        ConversationTopic @relation(fields: [topicId], references: [id])
}

model SpeakingProgress {
  id             String   @id @default(cuid())
  studentId      String   @unique
  currentLevel   Int      @default(1)
  passedSessions Int      @default(0)
  totalSessions  Int      @default(0)
  avgWpm         Float    @default(0)
  avgFluency     Float    @default(0)
  updatedAt      DateTime @updatedAt
  student        Student  @relation(fields: [studentId], references: [id])
}

model ReadingSession {
  id          String         @id @default(cuid())
  studentId   String
  passageId   String
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  durationSec Int?
  transcript  String?
  wpm         Float?
  accuracy    Float?
  missedWords String[]
  wrongWords  Json?
  status      SessionStatus  @default(IN_PROGRESS)
  teacherNote String?
  createdAt   DateTime       @default(now())
  passage     ReadingPassage @relation(fields: [passageId], references: [id])
  student     Student        @relation(fields: [studentId], references: [id])
}

model Badge {
  id        String    @id @default(cuid())
  studentId String
  type      BadgeType
  earnedAt  DateTime  @default(now())
  student   Student   @relation(fields: [studentId], references: [id])

  @@unique([studentId, type])
}

model Certificate {
  id         String    @id @default(cuid())
  studentId  String
  badgeType  BadgeType
  verifyCode String    @unique @default(cuid())
  issuedAt   DateTime  @default(now())
  student    Student   @relation(fields: [studentId], references: [id])

  @@unique([studentId, badgeType])
}

enum AccountType {
  SCHOOL
  PUBLIC
}

enum Gender {
  MALE
  FEMALE
}

enum BadgeType {
  SPARK
  WORD_WIZARD
  VOICE_WIZARD
  LANGUAGE_WIZARD
  GRAND_WIZARD
}

enum AdminRole {
  PRINCIPAL
  ACADEMIC_INCHARGE
}

enum GradeBand {
  BAND_1_2
  BAND_3_5
  BAND_6_8
  BAND_9_10
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  NEEDS_REVIEW
}

enum TopicMode {
  AI
  SCRIPTED
}
