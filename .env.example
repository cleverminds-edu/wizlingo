# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/wizlingo"

# App URL - Update after pilot
# PILOT PHASE (Jun-Jul 2026): Use subdomain
NEXT_PUBLIC_APP_URL="https://wizlingo.edvanta.co.in"

# SUBSCRIBER PHASE (Aug+ 2026): Change to:
# NEXT_PUBLIC_APP_URL="https://wizlingo.app"

# Authentication
JWT_SECRET="generate-with: openssl rand -base64 32"
WIZADMIN_SECRET="generate-with: openssl rand -base64 32"

# AI Provider
ANTHROPIC_API_KEY="sk-ant-..."  # Get from https://console.anthropic.com

# Optional
OPENAI_API_KEY="sk-..."  # If using OpenAI for additional features
NODE_ENV="development"
